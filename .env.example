# FlashNote 本地开发环境变量
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# Anthropic API Key（用于 AI 解析）
FLASHNOTE_ANTHROPIC_KEY=sk-ant-...

# DeepSeek API Key
FLASHNOTE_DEEPSEEK_KEY=sk-...

# 测试用 Anthropic Key（可选，仅运行 AI 集成测试时需要）
FLASHNOTE_TEST_ANTHROPIC_KEY=sk-ant-...

# Notion OAuth Client ID（公开信息，可从 Notion Developer Portal 获取）
FLASHNOTE_NOTION_CLIENT_ID=39ed872b-...

# Notion OAuth Client Secret（不要提交到 Git）
FLASHNOTE_NOTION_CLIENT_SECRET=secret_...
