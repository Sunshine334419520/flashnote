{
  "name": "flashnote",
  "version": "0.1.0",
  "description": "闪记 — AI-native smart note-taking app",
  "main": "./out/main/index.js",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "electron-vite dev",
    "predev": "electron-rebuild -f -w better-sqlite3",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.preload.json",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "vitest run",
    "pretest": "npm rebuild better-sqlite3 2>/dev/null; node -e \"require('better-sqlite3')\"",
    "test:watch": "vitest",
    "test:single": "vitest run --reporter=verbose",
    "test:e2e": "playwright test",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "immer": "^10.1.1",
    "lucide-react": "^0.460.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^9.0.3",
    "react-router-dom": "^7.1.0",
    "react-virtuoso": "^4.12.3",
    "tailwind-merge": "^2.6.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "commander": "^13.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vite": "^8.0.16",
    "vitest": "^2.1.0"
  }
}
